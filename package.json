{
  "name": "greensmart-landing",
  "version": "1.0.0",
  "description": "GreenSmart - 智能自动浇水花盆官方网站",
  "main": "index.html",
  "scripts": {
    "dev": "node server.js",
    "build": "mkdir -p dist && cp -r index.html src _headers dist/",
    "deploy": "npm run build && rsync -avz dist/ user@your-server:/var/www/html/",
    "start": "node server.js",
    "qa:check": "node qa-check.js"
  },
  "keywords": [
    "smart",
    "planter",
    "self-watering",
    "garden",
    "iot"
  ],
